#!/bin/sh

# Find the thermal zone that has the pwm-fan as a cooling device
find_thermal_zone() {
  for zone in /sys/class/thermal/thermal_zone*; do
    for cdev in "${zone}"/cdev*; do
      [ -e "${cdev}" ] || continue
      CDEV_NAME=$(readlink "$cdev" 2>/dev/null | xargs basename 2>/dev/null)
      if [ -n "$CDEV_NAME" ]; then
        TYPE=$(cat "/sys/class/thermal/${CDEV_NAME}/type" 2>/dev/null)
        if [ "$TYPE" = "pwm-fan" ]; then
          basename "$zone"
          return
        fi
      fi
    done
  done
  echo "thermal_zone0"
}

# Find first writable PWM sysfs node (skips pwmN_* attribute files)
find_pwm_device() {
  for hwmon in /sys/class/hwmon/hwmon*; do
    for pwm in "${hwmon}"/pwm[0-9]; do
      [ -w "$pwm" ] && echo "$pwm" && return
    done
  done
}

load_uci() {
  THERMAL=$(uci -q get fancontrol.settings.thermal)
  PWM=$(uci -q get fancontrol.settings.pwm)
  TEMP_OFF=$(uci -q get fancontrol.settings.temp_off);   TEMP_OFF=${TEMP_OFF:-60}
  TEMP_HALF=$(uci -q get fancontrol.settings.temp_half); TEMP_HALF=${TEMP_HALF:-65}
  TEMP_FULL=$(uci -q get fancontrol.settings.temp_full); TEMP_FULL=${TEMP_FULL:-75}
  HYST=$(uci -q get fancontrol.settings.hyst);           HYST=${HYST:-2}
  POLL=$(uci -q get fancontrol.settings.poll);           POLL=${POLL:-10}
  [ -z "$THERMAL" ] && THERMAL="/sys/class/thermal/$(find_thermal_zone)/temp"
  [ -z "$PWM"     ] && PWM=$(find_pwm_device)
}

# Build list of non-critical trip point indices for a given zone path.
# Sets globals: WRITABLE_TRIPS (space-separated indices) and NWRITABLE (count).
# trip_point_N_type = "critical" triggers a hardware emergency shutdown when
# crossed — we must never overwrite those.
get_writable_trips() {
  local i=0 type
  WRITABLE_TRIPS=""
  NWRITABLE=0
  while [ -f "${1}/trip_point_${i}_temp" ]; do
    type=$(cat "${1}/trip_point_${i}_type" 2>/dev/null)
    if [ "$type" != "critical" ]; then
      WRITABLE_TRIPS="${WRITABLE_TRIPS} ${i}"
      NWRITABLE=$(( NWRITABLE + 1 ))
    fi
    i=$(( i + 1 ))
  done
}

apply_trip_points() {
  # Spread trip points evenly across non-critical indices only.
  # Two passes (forward then reverse) handle both raising and lowering safely:
  # the kernel enforces ordering constraints during writes, so a single pass
  # can leave trip points inconsistent when all temps change simultaneously.
  local range=$(( TEMP_FULL - TEMP_OFF ))
  local trip_temp idx j rev_trips=""

  # Forward pass
  j=0
  for idx in $WRITABLE_TRIPS; do
    trip_temp=$(( TEMP_FULL - ( range * j / ( NWRITABLE - 1 ) ) ))
    echo "$(( trip_temp * 1000 ))" > "${ZONE_PATH}/trip_point_${idx}_temp" 2>/dev/null
    j=$(( j + 1 ))
  done

  # Reverse pass — build reversed index list, then write again
  for idx in $WRITABLE_TRIPS; do
    rev_trips="${idx} ${rev_trips}"
  done
  j=$(( NWRITABLE - 1 ))
  for idx in $rev_trips; do
    trip_temp=$(( TEMP_FULL - ( range * j / ( NWRITABLE - 1 ) ) ))
    echo "$(( trip_temp * 1000 ))" > "${ZONE_PATH}/trip_point_${idx}_temp" 2>/dev/null
    j=$(( j - 1 ))
  done

  logger -t fancontrol "Trip points set: off=${TEMP_OFF}C full=${TEMP_FULL}C across ${NWRITABLE} non-critical points (indices:${WRITABLE_TRIPS})"
}

LAST_CONF_HASH=""

while true; do
  load_uci

  if [ -z "$PWM" ]; then
    logger -t fancontrol "ERROR: No PWM device found and none configured"
    exit 1
  fi

  # Derive zone name from the thermal sensor path
  ZONE=$(echo "$THERMAL" | sed 's|/sys/class/thermal/\([^/]*\)/.*|\1|')

  CONF_HASH="${THERMAL}${PWM}${TEMP_OFF}${TEMP_HALF}${TEMP_FULL}${HYST}"
  if [ "$CONF_HASH" != "$LAST_CONF_HASH" ]; then
    ZONE_PATH="/sys/class/thermal/${ZONE}"
    get_writable_trips "$ZONE_PATH"
    logger -t fancontrol "Using thermal zone: $ZONE — ${NWRITABLE} non-critical trip points (indices:${WRITABLE_TRIPS})"

    if [ "$NWRITABLE" -lt 2 ]; then
      logger -t fancontrol "ERROR: Need at least 2 non-critical trip points in $ZONE (found $NWRITABLE)"
      exit 1
    fi

    # Set policy to step_wise so the kernel manages fan automatically
    echo step_wise > "${ZONE_PATH}/policy" 2>/dev/null

    # Ensure PWM is in auto mode so the thermal framework can drive it.
    # A previous install may have left pwm1_enable=1 (manual), which blocks
    # the step_wise governor from changing the actual PWM output.
    PWM_ENABLE="${PWM}_enable"
    [ -w "$PWM_ENABLE" ] && echo 2 > "$PWM_ENABLE" 2>/dev/null

    if [ "$TEMP_FULL" -le "$TEMP_OFF" ]; then
      logger -t fancontrol "ERROR: temp_full (${TEMP_FULL}) must be greater than temp_off (${TEMP_OFF}) - skipping trip point update"
      LAST_CONF_HASH=""
      sleep "$POLL"
      continue
    fi

    logger -t fancontrol "Fan control started - kernel thermal mode (off<${TEMP_OFF}C half<${TEMP_HALF}C full>${TEMP_FULL}C)"
    apply_trip_points
    LAST_CONF_HASH="$CONF_HASH"
  fi

  sleep "$POLL"
done
